<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.LibraryView"
			 x:DataType="vm:LibraryViewModel">

	<Grid RowDefinitions="auto,*">

		<Border Grid.Row="0"
				Padding="16,12">
			<StackPanel Orientation="Horizontal" Spacing="8">
				<TextBlock Text="Моя бібліотека"
						   FontSize="20"
						   FontWeight="Bold"
						   VerticalAlignment="Center"/>
				<Button Content="+ Додати гру"
						Click="OnAddGameClick"/>
			</StackPanel>
		</Border>
		<ListBox Grid.Row="1"
				 ItemsSource="{Binding Games}"
				 SelectedItem="{Binding SelectedGame}"
				 SelectionChanged="OnSelectionChanged">
			<ListBox.ItemTemplate>
				<DataTemplate x:DataType="models:Game">
					<Grid ColumnDefinitions="*,150,100" Width="600">
						<StackPanel Grid.Column="0" Spacing="2">
							<TextBlock Text="{Binding Title}"
									   FontWeight="SemiBold"/>
							<TextBlock Text="{Binding Developer.Name}"
									   FontSize="12"
									   Opacity="0.6"/>
						</StackPanel>
						<TextBlock Grid.Column="1"
								   Text="{Binding Platform}"
								   VerticalAlignment="Center"/>
						<TextBlock Grid.Column="2"
								   Text="{Binding Status}"
								   VerticalAlignment="Center"/>

					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>

	</Grid>

</UserControl>