<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
			 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.LibraryView"
			 x:DataType="vm:LibraryViewModel">

	<Grid RowDefinitions="auto,*">

		<Border Grid.Row="0" Padding="16,12">
			<Grid ColumnDefinitions="Auto,*">

				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<TextBlock Text="Моя бібліотека"
							   FontSize="20"
							   FontWeight="Bold"
							   VerticalAlignment="Center"/>
					<Button Content="+ Додати гру"
							Click="OnAddGameClick"
							VerticalAlignment="Center"/>
				</StackPanel>

				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
							HorizontalAlignment="Right" VerticalAlignment="Center">

					<TextBox Text="{Binding SearchText}"
							 Watermark="🔍  Пошук..."
							 Width="180"
							 VerticalAlignment="Center"/>

					<ComboBox ItemsSource="{Binding AvailableGenres}"
							  SelectedItem="{Binding SelectedGenre}"
							  Width="120"
							  VerticalAlignment="Center">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding, TargetNullValue='Жанр'}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>

					<ComboBox ItemsSource="{Binding AvailablePlatforms}"
							  SelectedItem="{Binding SelectedPlatform}"
							  Width="120"
							  VerticalAlignment="Center">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding, TargetNullValue='Платформа'}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>

					<ComboBox ItemsSource="{Binding AvailableDevelopers}"
							  SelectedItem="{Binding SelectedDeveloper}"
							  Width="140"
							  VerticalAlignment="Center">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding Name, TargetNullValue='Розробник', FallbackValue='Розробник'}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>

					<ComboBox ItemsSource="{Binding AvailableStatuses}"
							  SelectedItem="{Binding SelectedStatusFilter}"
							  Width="120"
							  VerticalAlignment="Center">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding, TargetNullValue='Статус'}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>

					<Button Content="✕"
							Command="{Binding ClearFiltersCommand}"
							VerticalAlignment="Center"
							ToolTip.Tip="Скинути фільтри"/>

				</StackPanel>

			</Grid>
		</Border>
		<Grid Grid.Row="1">

			<ListBox ItemsSource="{Binding FilteredGames}"
					 SelectedItem="{Binding SelectedGame}"
					 SelectionChanged="OnSelectionChanged"
					 IsVisible="{Binding !IsEmpty}">
				<ListBox.ItemTemplate>
					<DataTemplate x:DataType="models:Game">
						<Grid ColumnDefinitions="*,150,100" Width="600">
							<StackPanel Grid.Column="0" Spacing="2">
								<TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding Developer.Name}"
										   FontSize="12" Opacity="0.6"/>
							</StackPanel>
							<TextBlock Grid.Column="1" Text="{Binding Platform}"
									   VerticalAlignment="Center"/>
							<TextBlock Grid.Column="2" Text="{Binding Status}"
									   VerticalAlignment="Center"/>
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<StackPanel IsVisible="{Binding IsEmpty}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="16">
				<TextBlock Text="🎮"
						   FontSize="48"
						   HorizontalAlignment="Center"/>
				<TextBlock Text="Бібліотека порожня"
						   FontSize="18"
						   FontWeight="SemiBold"
						   HorizontalAlignment="Center"/>
				<TextBlock Text="Додай свою першу гру щоб почати"
						   Opacity="0.6"
						   HorizontalAlignment="Center"/>
				<Button Content="+ Додати гру"
						Click="OnAddGameClick"
						HorizontalAlignment="Center"
						Padding="24,10"
						FontSize="14"/>
			</StackPanel>

		</Grid>
	</Grid>

</UserControl>