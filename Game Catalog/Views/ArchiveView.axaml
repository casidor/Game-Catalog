<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 xmlns:conv="using:Game_Catalog.Converters"
			 x:Class="Game_Catalog.Views.ArchiveView"
			 x:DataType="vm:ArchiveViewModel">

	<Grid RowDefinitions="auto,auto,*">

		<Border Grid.Row="0" Padding="16,12">
			<Grid ColumnDefinitions="Auto,*">
				<TextBlock Grid.Column="0" Text="Архів"
						   FontSize="20" FontWeight="Bold"
						   VerticalAlignment="Center"/>
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
							HorizontalAlignment="Right" VerticalAlignment="Center">
					<TextBox Text="{Binding SearchText}"
							 Watermark="🔍  Пошук..."
							 Width="180" VerticalAlignment="Center"/>
					<Button Content="⚙ Фільтри"
							Command="{Binding ToggleFiltersCommand}"
							VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<Border Grid.Row="1"
				Padding="16,10"
				IsVisible="{Binding IsFiltersVisible}"
				Background="{DynamicResource CardBackground}"
				BorderBrush="{DynamicResource SidebarBorder}"
				BorderThickness="0,1,0,1">
			<WrapPanel Orientation="Horizontal">
				<ComboBox ItemsSource="{Binding AvailableGenres}"
						  SelectedItem="{Binding SelectedGenre}"
						  Width="140" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding, TargetNullValue='Жанр'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<ComboBox ItemsSource="{Binding AvailablePlatforms}"
						  SelectedItem="{Binding SelectedPlatform}"
						  Width="140" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding, TargetNullValue='Платформа'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<ComboBox ItemsSource="{Binding AvailableDevelopers}"
						  SelectedItem="{Binding SelectedDeveloper}"
						  Width="160" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding Name, TargetNullValue='Розробник', FallbackValue='Розробник'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<ComboBox ItemsSource="{Binding AvailableStatuses}"
						  SelectedItem="{Binding SelectedStatusFilter}"
						  Width="140" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding, Converter={x:Static conv:GameStatusConverter.Instance}, TargetNullValue='Статус'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<Button Content="✕ Скинути"
						Command="{Binding ClearFiltersCommand}"
						Margin="0,0,0,8"/>
			</WrapPanel>
		</Border>

		<Grid Grid.Row="2" RowDefinitions="Auto,*">

			<Border Grid.Row="0"
					Padding="16,8"
					BorderBrush="{DynamicResource SidebarBorder}"
					BorderThickness="0,0,0,1">
				<Grid ColumnDefinitions="*,150,100">
					<TextBlock Grid.Column="0" Text="Назва"     FontSize="12" Opacity="0.5"/>
					<TextBlock Grid.Column="1" Text="Платформа" FontSize="12" Opacity="0.5"/>
					<TextBlock Grid.Column="2" Text="Статус"    FontSize="12" Opacity="0.5"/>
				</Grid>
			</Border>

			<ListBox Grid.Row="1"
					 ItemsSource="{Binding FilteredGames}"
					 SelectedItem="{Binding SelectedGame}"
					 SelectionChanged="OnSelectionChanged"
					 IsVisible="{Binding !IsEmpty}">
				<ListBox.ItemTemplate>
					<DataTemplate x:DataType="models:Game">
						<Grid ColumnDefinitions="*,150,100" Width="600">
							<StackPanel Grid.Column="0" Spacing="2">
								<TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding Developer.Name}" FontSize="12" Opacity="0.6"/>
							</StackPanel>
							<TextBlock Grid.Column="1" Text="{Binding Platform}" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="2"
									   Text="{Binding Status, Converter={x:Static conv:GameStatusConverter.Instance}}"
									   VerticalAlignment="Center"/>
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<StackPanel Grid.Row="1"
						IsVisible="{Binding IsEmpty}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="16">
				<TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center"/>
				<TextBlock Text="Архів порожній" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
				<TextBlock Text="Перенесені ігри з'являться тут" Opacity="0.6" HorizontalAlignment="Center"/>
			</StackPanel>

		</Grid>

	</Grid>
</UserControl>