<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:Game_Catalog.ViewModels"
		x:Class="Game_Catalog.Views.ConfirmationWindow"
		x:DataType="vm:ConfirmationViewModel"
		Title="{Binding Title}"
		Width="380"
		SizeToContent="Height"
		WindowStartupLocation="CenterOwner"
		CanResize="False">

	<StackPanel Spacing="16" Margin="24">

		<TextBlock Text="{Binding Title}"
				   FontSize="15"
				   FontWeight="SemiBold"
				   TextWrapping="Wrap"/>

		<TextBlock Text="{Binding Message}"
				   Opacity="0.7"
				   TextWrapping="Wrap"
				   FontSize="13"/>

		<StackPanel Orientation="Horizontal"
					Spacing="8"
					HorizontalAlignment="Right"
					Margin="0,8,0,0">
			<Button Content="{Binding CancelText}"
					Command="{Binding CancelCommand}"
					IsVisible="{Binding !IsAlert}"/>
			<Button Content="{Binding ConfirmText}"
					Command="{Binding ConfirmCommand}"/>
		</StackPanel>

	</StackPanel>
</Window>