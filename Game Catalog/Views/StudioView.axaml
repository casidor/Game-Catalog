<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Game_Catalog.ViewModels"
             xmlns:models="using:Game_Catalog.Models"
             x:Class="Game_Catalog.Views.StudioView"
             x:DataType="vm:StudioViewModel">

    <Grid RowDefinitions="auto,*">
        <Border Grid.Row="0" Padding="16,12">
            <Grid ColumnDefinitions="Auto,*">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <TextBlock Text="Студії" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="+ Додати студію" Click="OnAddStudioClick" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" 
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    
                    <TextBox Text="{Binding SearchText}" 
                             Watermark="🔍 Пошук студії..." 
                             Width="180" VerticalAlignment="Center"/>

                    <ComboBox ItemsSource="{Binding AvailableCountries}" 
                             SelectedItem="{Binding SelectedCountry}" 
                             Width="150" VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding, TargetNullValue='Всі країни'}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ComboBox ItemsSource="{Binding AvailableGenres}" 
                             SelectedItem="{Binding SelectedGenre}" 
                             Width="150" VerticalAlignment="Center">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding, TargetNullValue='Всі жанри'}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <ListBox Grid.Row="1"
                 ItemsSource="{Binding FilteredStudios}"
                 SelectedItem="{Binding SelectedStudio}"
                 SelectionChanged="OnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:Studio">
                    <Grid ColumnDefinitions="*,150,100" Width="600">
                        <StackPanel Grid.Column="0" Spacing="2">
                            <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Country}" FontSize="12" Opacity="0.6"/>
                        </StackPanel>
                        <TextBlock Grid.Column="1" Text="{Binding FoundationYear}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="{Binding MainGenre}" VerticalAlignment="Center"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </Grid>
</UserControl>