<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.StudioView"
			 x:DataType="vm:StudioViewModel">

	<Grid RowDefinitions="auto,auto,*">

		<!-- Toolbar -->
		<Border Grid.Row="0" Padding="16,12">
			<Grid ColumnDefinitions="Auto,*">
				<StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
					<TextBlock Text="Студії"
							   FontSize="20" FontWeight="Bold"
							   VerticalAlignment="Center"/>
					<Button Content="+ Додати студію"
							Click="OnAddStudioClick"
							VerticalAlignment="Center"/>
				</StackPanel>
				<StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8"
							HorizontalAlignment="Right" VerticalAlignment="Center">
					<TextBox Text="{Binding SearchText}"
							 Watermark="🔍 Пошук студії..."
							 Width="180" VerticalAlignment="Center"/>
					<Button Content="⚙ Фільтри"
							Command="{Binding ToggleFiltersCommand}"
							VerticalAlignment="Center"/>
				</StackPanel>
			</Grid>
		</Border>

		<!-- Filter panel -->
		<Border Grid.Row="1"
				Padding="16,10"
				IsVisible="{Binding IsFiltersVisible}"
				Background="{DynamicResource CardBackground}"
				BorderBrush="{DynamicResource SidebarBorder}"
				BorderThickness="0,1,0,1">
			<WrapPanel Orientation="Horizontal">
				<ComboBox ItemsSource="{Binding AvailableCountries}"
						  SelectedItem="{Binding SelectedCountry}"
						  Width="160" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding, TargetNullValue='Країна'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<ComboBox ItemsSource="{Binding AvailableGenres}"
						  SelectedItem="{Binding SelectedGenre}"
						  Width="140" Margin="0,0,8,8">
					<ComboBox.ItemTemplate>
						<DataTemplate>
							<TextBlock Text="{Binding, TargetNullValue='Жанр'}"/>
						</DataTemplate>
					</ComboBox.ItemTemplate>
				</ComboBox>
				<Button Content="✕ Скинути"
						Command="{Binding ClearFiltersCommand}"
						Margin="0,0,0,8"/>
			</WrapPanel>
		</Border>

		<Grid Grid.Row="2" RowDefinitions="Auto,*">

			<!-- Table header -->
			<Border Grid.Row="0"
					Padding="16,8"
					BorderBrush="{DynamicResource SidebarBorder}"
					BorderThickness="0,0,0,1">
				<Grid ColumnDefinitions="*,150,100">
					<TextBlock Grid.Column="0" Text="Назва"           FontSize="12" Opacity="0.5"/>
					<TextBlock Grid.Column="1" Text="Рік заснування"  FontSize="12" Opacity="0.5"/>
					<TextBlock Grid.Column="2" Text="Жанр"            FontSize="12" Opacity="0.5"/>
				</Grid>
			</Border>

			<!-- Studios list -->
			<ListBox Grid.Row="1"
					 ItemsSource="{Binding FilteredStudios}"
					 SelectedItem="{Binding SelectedStudio}"
					 SelectionChanged="OnSelectionChanged"
					 IsVisible="{Binding !IsEmpty}">
				<ListBox.ItemTemplate>
					<DataTemplate x:DataType="models:Studio">
						<Grid ColumnDefinitions="*,150,100">
							<StackPanel Grid.Column="0" Spacing="2">
								<TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
								<TextBlock Text="{Binding Country}" FontSize="12" Opacity="0.6"/>
							</StackPanel>
							<TextBlock Grid.Column="1" Text="{Binding FoundationYear}" VerticalAlignment="Center"/>
							<TextBlock Grid.Column="2" Text="{Binding MainGenre}"      VerticalAlignment="Center"/>
						</Grid>
					</DataTemplate>
				</ListBox.ItemTemplate>
			</ListBox>

			<!-- Empty studios state -->
			<StackPanel Grid.Row="1"
						IsVisible="{Binding IsEmpty}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="16">
				<TextBlock Text="🏢" FontSize="48" HorizontalAlignment="Center"/>
				<TextBlock Text="Студій немає" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
				<TextBlock Text="Додай свою першу студію щоб почати" Opacity="0.6" HorizontalAlignment="Center"/>
				<Button Content="+ Додати студію"
						Click="OnAddStudioClick"
						HorizontalAlignment="Center"
						Padding="24,10" FontSize="14"/>
			</StackPanel>

			<!-- Filtered empty state -->
			<StackPanel Grid.Row="1"
						IsVisible="{Binding IsFilteredEmpty}"
						HorizontalAlignment="Center"
						VerticalAlignment="Center"
						Spacing="12">
				<TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center"/>
				<TextBlock Text="Студій не знайдено" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center"/>
				<TextBlock Text="Спробуйте змінити критерії пошуку" Opacity="0.6" HorizontalAlignment="Center"/>
			</StackPanel>
		</Grid>

	</Grid>
</UserControl>