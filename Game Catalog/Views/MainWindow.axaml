<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:Game_Catalog.ViewModels"
		xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
		xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		mc:Ignorable="d" d:DesignWidth="1100" d:DesignHeight="700"
		x:Class="Game_Catalog.Views.MainWindow"
		x:DataType="vm:MainWindowViewModel"
		Title="Game Catalog"
		MinWidth="900"
		MinHeight="600"
		Background="{DynamicResource AppBackground}">

	<Design.DataContext>
		<vm:MainWindowViewModel/>
	</Design.DataContext>

	<Grid ColumnDefinitions="220,*">

		<!-- Sidebar -->
		<Border Grid.Column="0"
        Background="{DynamicResource SidebarBackground}"
        BorderBrush="{DynamicResource SidebarBorder}"
        BorderThickness="0,0,1,0">
    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Logo -->
        <Border Grid.Row="0" Padding="24,32,24,24">
            <StackPanel Spacing="4">
                <TextBlock Text="🎮" FontSize="28"/>
                <TextBlock Text="Game Catalog"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="{DynamicResource LogoForeground}"/>
                <TextBlock Text="My Library"
                           FontSize="11"
                           Foreground="{DynamicResource SubtitleForeground}"/>
            </StackPanel>
        </Border>

        <!-- Navigation buttons -->
        <StackPanel Grid.Row="1" Spacing="4" Margin="12,0">
            <Button Content="🎮  Бібліотека"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{Binding LibraryPage}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,12" FontSize="14"
                    Background="Transparent"
                    Foreground="{DynamicResource NavForeground}" CornerRadius="8"/>
            <Button Content="🏢  Студії"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{Binding StudioPage}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,12" FontSize="14"
                    Background="Transparent"
                    Foreground="{DynamicResource NavForeground}" CornerRadius="8"/>
            <Button Content="📦  Архів"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{Binding ArchivePage}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,12" FontSize="14"
                    Background="Transparent"
                    Foreground="{DynamicResource NavForeground}" CornerRadius="8"/>
            <Button Content="📊  Статистика"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{Binding StatisticsPage}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,12" FontSize="14"
                    Background="Transparent"
                    Foreground="{DynamicResource NavForeground}" CornerRadius="8"/>
        </StackPanel>

        <!-- Settings pinned to bottom -->
        <Border Grid.Row="2" Padding="12,12">
            <Button Content="⚙  Налаштування"
                    Command="{Binding NavigateToCommand}"
                    CommandParameter="{Binding SettingsPage}"
                    HorizontalAlignment="Stretch"
                    HorizontalContentAlignment="Left"
                    Padding="16,12" FontSize="14"
                    Background="Transparent"
                    Foreground="{DynamicResource NavForeground}" CornerRadius="8"/>
        </Border>

    </Grid>
</Border>

		<!-- Main content -->
		<Border Grid.Column="1"
				Background="{DynamicResource AppBackground}">
			<ContentControl Content="{Binding CurrentPage}"/>
		</Border>

	</Grid>

</Window>