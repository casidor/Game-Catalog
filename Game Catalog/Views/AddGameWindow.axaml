<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:Game_Catalog.ViewModels"
		x:Class="Game_Catalog.Views.AddGameWindow"
		xmlns:models="using:Game_Catalog.Models"
		x:DataType="vm:AddGameViewModel"
		Title="{Binding WindowTitle}"
		Width="450"
		MaxHeight="750"
		SizeToContent="Height"
		WindowStartupLocation="CenterOwner"
		CanResize="False">

	<Grid RowDefinitions="*,Auto">

		<ScrollViewer Grid.Row="0">
			<StackPanel Spacing="12" Margin="24">

				<!-- Назва -->
				<TextBlock Text="Назва гри"/>
				<Panel>
					<TextBox x:Name="TitleBox"
							 Text="{Binding Title}"
							 Watermark="Введіть назву..."/>
					<Popup IsOpen="{Binding IsSuggestionsVisible}"
						   PlacementTarget="{Binding ElementName=TitleBox}"
						   Placement="Bottom"
						   MinWidth="400">
						<Border Background="{DynamicResource CardBackground}"
								BorderBrush="{DynamicResource SidebarBorder}"
								BorderThickness="1"
								CornerRadius="0,0,4,4"
								MaxHeight="220">
							<ListBox x:Name="SuggestionsList"
									 ItemsSource="{Binding Suggestions}"
									 Background="Transparent"
									 SelectionChanged="OnSuggestionSelected">
								<ListBox.ItemTemplate>
									<DataTemplate x:DataType="models:RawgGameResult">
										<TextBlock Text="{Binding Name}" Padding="4,2"/>
									</DataTemplate>
								</ListBox.ItemTemplate>
							</ListBox>
						</Border>
					</Popup>
				</Panel>
				<TextBlock Text="🔍 Пошук у RAWG..."
						   FontSize="11"
						   Opacity="0.5"
						   IsVisible="{Binding IsSearching}"/>

				<!-- Студія -->
				<TextBlock Text="Студія-розробник"/>
				<Grid ColumnDefinitions="*,Auto">
					<ComboBox Grid.Column="0"
							  ItemsSource="{Binding Studios}"
							  SelectedItem="{Binding SelectedStudio}"
							  HorizontalAlignment="Stretch">
						<ComboBox.ItemTemplate>
							<DataTemplate>
								<TextBlock Text="{Binding Name}"/>
							</DataTemplate>
						</ComboBox.ItemTemplate>
					</ComboBox>
					<Button Grid.Column="1"
							Content="+"
							Click="OnAddStudioClick"
							Margin="8,0,0,0"
							Padding="10,0"
							FontSize="16"
							VerticalAlignment="Stretch"
							ToolTip.Tip="Додати студію"/>
				</Grid>
				<ItemsControl ItemsSource="{Binding SuggestedDeveloperNames}"
							  IsVisible="{Binding HasSuggestedDevelopers}">
					<ItemsControl.ItemTemplate>
						<DataTemplate>
							<Button Content="{Binding StringFormat='+ Додати &quot;{0}&quot; до бази?'}"
									Tag="{Binding}"
									Click="OnSuggestStudioClick"
									Background="Transparent"
									Foreground="#4a9eff"
									Padding="0,2"
									Cursor="Hand"
									HorizontalAlignment="Left"/>
						</DataTemplate>
					</ItemsControl.ItemTemplate>
				</ItemsControl>

				<!-- Жанр -->
				<TextBlock Text="Жанр"/>
				<TextBox Text="{Binding Genre}"
						 Watermark="Введіть жанр..."/>

				<!-- Рік випуску -->
				<TextBlock Text="Рік випуску"/>
				<NumericUpDown Value="{Binding ReleaseYear}"
							   Minimum="1970"
							   Maximum="2030"
							   FormatString="0"/>

				<!-- Платформа -->
				<TextBlock Text="Платформа"/>
				<TextBox Text="{Binding Platform}"
						 Watermark="PC, PlayStation, Xbox..."/>

				<!-- Розмір -->
				<TextBlock Text="Розмір на диску (ГБ)"/>
				<NumericUpDown Value="{Binding SizeGB}"
							   Minimum="0"
							   Maximum="1000"
							   Increment="0.5"
							   FormatString="0.0"/>

				<!-- Статус -->
				<TextBlock Text="Статус"/>
				<ComboBox ItemsSource="{Binding Statuses}"
						  SelectedItem="{Binding Status}"
						  HorizontalAlignment="Stretch"/>

				<!-- Години -->
				<TextBlock Text="Години в грі"/>
				<NumericUpDown Value="{Binding HoursPlayed}"
							   Minimum="0"
							   Maximum="10000"
							   Increment="0.5"
							   FormatString="0.0"/>

				<!-- Оцінка -->
				<TextBlock Text="Особиста оцінка (1-10)"/>
				<NumericUpDown Value="{Binding PersonalRating}"
							   Minimum="1"
							   Maximum="10"
							   FormatString="0"/>

			</StackPanel>
		</ScrollViewer>
		<Border Grid.Row="1"
				Padding="24,12"
				BorderBrush="{DynamicResource SidebarBorder}"
				BorderThickness="0,1,0,0">
			<StackPanel Orientation="Horizontal"
						Spacing="8"
						HorizontalAlignment="Right">
				<Button Content="Скасувати"
						Command="{Binding CancelCommand}"/>
				<Button Content="Зберегти"
						Command="{Binding ConfirmCommand}"/>
			</StackPanel>
		</Border>
	</Grid>
</Window>