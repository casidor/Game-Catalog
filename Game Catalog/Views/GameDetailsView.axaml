<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.GameDetailsView"
			 x:DataType="vm:GameDetailsViewModel">
<Grid RowDefinitions="auto,auto,*">

    <!-- Заголовок -->
    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,0">
        <Button Content="← Назад"
                Command="{Binding GoBackCommand}"
                Padding="8,4"
                Margin="16,16,16,0"/>
        <TextBlock Text="{Binding Title}"
                   FontSize="24"
                   FontWeight="Bold"
                   VerticalAlignment="Center"
                   Margin="16,16,16,0"/>
    </StackPanel>

    <!-- Банер -->
    <Border Grid.Row="1"
            MaxHeight="400"
            Margin="0,12,0,0"
            CornerRadius="8"
            ClipToBounds="True">
        <Panel>

            <!-- Обкладинка -->
            <Image Source="{Binding CoverImage}"
                   Stretch="UniformToFill"
                   IsVisible="{Binding HasCover}"/>

            <!-- Плейсхолдер -->
            <Border Background="{DynamicResource CardBackground}"
                    IsVisible="{Binding !HasCover}">
                <TextBlock Text="🎮"
                           FontSize="64"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Градієнт -->
            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                        <GradientStop Color="Transparent" Offset="0.4"/>
                        <GradientStop Color="#CC000000"  Offset="1.0"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Оцінка поверх банера -->
            <TextBlock Text="{Binding PersonalRating, StringFormat='Оцінка: {0}/10'}"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Right"
                       Margin="0,0,16,12"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"/>

        </Panel>
    </Border>

    <!-- Контент -->
    <ScrollViewer Grid.Row="2" Margin="16,16,0,0">
        <StackPanel Spacing="16">

            <!-- Кнопки дій -->
            <StackPanel Orientation="Horizontal" Spacing="8">
                <Button Content="✏ Редагувати"
                        Click="OnEditClick"
                        IsVisible="{Binding !IsArchived}"/>
                <Button Content="📦 В архів"
                        Click="OnArchiveClick"
                        IsVisible="{Binding !IsArchived}"/>
                <Button Content="♻ Відновити"
                        Click="OnRestoreClick"
                        IsVisible="{Binding IsArchived}"/>
                <Button Content="🗑 Видалити"
                        Click="OnDeleteClick"/>
            </StackPanel>

            <!-- Характеристики -->
            <WrapPanel Orientation="Horizontal">

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Жанр" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding Genre}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Рік випуску" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding ReleaseYear}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Платформа" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding Platform}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Розробник" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding DeveloperName}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Статус" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding Status}" FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Годин зіграно" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding HoursPlayed, StringFormat='{}{0} год'}"
                                   FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

                <Border Background="{DynamicResource CardBackground}"
                        CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
                    <StackPanel Spacing="4">
                        <TextBlock Text="Розмір на диску" FontSize="11" Opacity="0.5"/>
                        <TextBlock Text="{Binding SizeGB, StringFormat='{}{0} ГБ'}"
                                   FontSize="14" FontWeight="SemiBold"/>
                    </StackPanel>
                </Border>

            </WrapPanel>

            <!-- Опис -->
            <StackPanel Spacing="8" IsVisible="{Binding HasDescription}">
                <TextBlock Text="Опис" FontSize="12" Opacity="0.5"/>
                <TextBlock Text="{Binding Description}"
                           TextWrapping="Wrap"
                           FontSize="14"
                           LineHeight="22"
                           Opacity="0.85"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>

</Grid>
</UserControl>
