<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.GameDetailsView"
			 x:DataType="vm:GameDetailsViewModel">

	<Grid RowDefinitions="auto,*">
		<StackPanel Grid.Row="0" Orientation="Horizontal">
			<Button Content="← Назад"
					Command="{Binding GoBackCommand}"
					Padding="8,4"
					Margin="0,0,16,0"/>
			<TextBlock Text="{Binding Title}"
					   FontSize="24"
					   FontWeight="Bold"
					   Padding="0"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<Grid Grid.Row="1" ColumnDefinitions="300,*">

			<Border Grid.Column="0"
					Margin="0,16,16,0"
					Background="{DynamicResource CardBackground}"
					CornerRadius="8">
				<Image Source="{Binding}"
					   Stretch="UniformToFill"/>
			</Border>

			<StackPanel Grid.Column="1"
						Margin="0,16,0,0"
						Spacing="12">
				<StackPanel Orientation="Horizontal" Spacing="8">
    <Button Content="✏ Редагувати"
            Click="OnEditClick"
            IsVisible="{Binding !IsArchived}"/>
    <Button Content="📦 В архів"
            Click="OnArchiveClick"
            IsVisible="{Binding !IsArchived}"/>
    <Button Content="♻ Відновити"
            Click="OnRestoreClick"
            IsVisible="{Binding IsArchived}"/>
    <Button Content="🗑 Видалити"
            Click="OnDeleteClick"/>
</StackPanel>

				<StackPanel Spacing="2">
					<TextBlock Text="Жанр" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding Genre}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Рік випуску" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding ReleaseYear}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Платформа" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding Platform}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Розмір на диску" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding SizeGB, StringFormat='{}{0} ГБ'}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Статус" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding Status}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Годин зіграно" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding HoursPlayed, StringFormat='{}{0} год'}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Оцінка" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding PersonalRating, StringFormat='{}{0}/10'}" FontSize="16"/>
				</StackPanel>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
