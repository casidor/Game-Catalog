<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 xmlns:conv="using:Game_Catalog.Converters"
			 x:Class="Game_Catalog.Views.StudioDetailsView"
			 x:DataType="vm:StudioDetailsViewModel">

	<Grid RowDefinitions="auto,*">

		<!-- Заголовок -->
		<StackPanel Grid.Row="0" Orientation="Horizontal" Margin="16,16,16,0">
			<Button Content="← Назад"
					Command="{Binding GoBackCommand}"
					Padding="8,4"
					Margin="0,0,16,0"/>
			<TextBlock Text="{Binding Name}"
					   FontSize="24"
					   FontWeight="Bold"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Контент -->
		<ScrollViewer Grid.Row="1" Margin="16,16,16,0">
			<StackPanel Spacing="16">

				<!-- Кнопки дій -->
				<StackPanel Orientation="Horizontal" Spacing="8">
					<Button Content="✏ Редагувати" Click="OnEditClick"/>
					<Button Content="🗑 Видалити"   Click="OnDeleteClick"/>
				</StackPanel>

				<!-- Картки -->
				<WrapPanel Orientation="Horizontal">
					<Border Background="{DynamicResource CardBackground}"
							CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
						<StackPanel Spacing="4">
							<TextBlock Text="Країна" FontSize="11" Opacity="0.5"/>
							<TextBlock Text="{Binding DisplayCountry}" FontSize="14" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
					<Border Background="{DynamicResource CardBackground}"
							CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
						<StackPanel Spacing="4">
							<TextBlock Text="Рік заснування" FontSize="11" Opacity="0.5"/>
							<TextBlock Text="{Binding DisplayFoundationYear}" FontSize="14" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
					<Border Background="{DynamicResource CardBackground}"
							CornerRadius="8" Padding="16" Margin="0,0,8,8" MinWidth="140">
						<StackPanel Spacing="4">
							<TextBlock Text="Основний жанр" FontSize="11" Opacity="0.5"/>
							<TextBlock Text="{Binding DisplayMainGenre}" FontSize="14" FontWeight="SemiBold"/>
						</StackPanel>
					</Border>
				</WrapPanel>

				<!-- Ігри студії -->
				<StackPanel Spacing="8">
					<TextBlock Text="Ігри у бібліотеці"
							   FontSize="14" Opacity="0.5"
							   IsVisible="{Binding HasGames}"/>
					<ListBox ItemsSource="{Binding StudioGames}"
							 IsVisible="{Binding HasGames}"
							 SelectionChanged="OnGameSelectionChanged">
						<ListBox.ItemTemplate>
							<DataTemplate x:DataType="models:Game">
								<Grid ColumnDefinitions="*,150,100">
									<StackPanel Grid.Column="0" Spacing="2">
										<TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
										<TextBlock Text="{Binding Genre}" FontSize="12" Opacity="0.6"/>
									</StackPanel>
									<TextBlock Grid.Column="1" Text="{Binding Platform}" VerticalAlignment="Center"/>
									<TextBlock Grid.Column="2" Text="{Binding Status, Converter={x:Static conv:GameStatusConverter.Instance}}" VerticalAlignment="Center"/>
								</Grid>
							</DataTemplate>
						</ListBox.ItemTemplate>
					</ListBox>
				</StackPanel>

			</StackPanel>
		</ScrollViewer>

	</Grid>
</UserControl>