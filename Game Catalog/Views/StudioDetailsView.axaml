<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 xmlns:models="using:Game_Catalog.Models"
			 x:Class="Game_Catalog.Views.StudioDetailsView"
			 x:DataType="vm:StudioDetailsViewModel">

	<Grid RowDefinitions="auto,*">
		<StackPanel Grid.Row="0" Orientation="Horizontal">
			<Button Content="← Назад"
					Command="{Binding GoBackCommand}"
					Padding="8,4"
					Margin="0,0,16,0"/>
			<TextBlock Text="{Binding Name}"
					   FontSize="24"
					   FontWeight="Bold"
					   Padding="0"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<Grid Grid.Row="1" ColumnDefinitions="300,*">

			<Border Grid.Column="0"
					Margin="0,16,16,0"
					Background="{DynamicResource CardBackground}"
					CornerRadius="8">
				<Image Source="{Binding}"
					   Stretch="UniformToFill"/>
			</Border>

			<StackPanel Grid.Column="1"
						Margin="0,16,0,0"
						Spacing="12">
				<StackPanel Orientation="Horizontal" Spacing="8">
    <Button Content="✏ Редагувати"
            Click="OnEditClick"/>
    <Button Content="🗑 Видалити"
            Click="OnDeleteClick"/>
</StackPanel>

				<StackPanel Spacing="2">
					<TextBlock Text="Назва" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding Name}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Країна" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding Country}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Рік заснування" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding FoundationYear}" FontSize="16"/>
				</StackPanel>
				<StackPanel Spacing="2">
					<TextBlock Text="Головний жанр" Opacity="0.6" FontSize="12"/>
					<TextBlock Text="{Binding MainGenre}" FontSize="16"/>
				</StackPanel>
			</StackPanel>
		</Grid>
	</Grid>
</UserControl>
