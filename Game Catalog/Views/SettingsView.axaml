<UserControl xmlns="https://github.com/avaloniaui"
			 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
			 xmlns:conv="using:Game_Catalog.Converters"
			 xmlns:vm="using:Game_Catalog.ViewModels"
			 x:Class="Game_Catalog.Views.SettingsView"
			 x:DataType="vm:SettingsViewModel">

	<StackPanel Margin="24" Spacing="24" MaxWidth="400">

		<TextBlock Text="Налаштування"
				   FontSize="20"
				   FontWeight="Bold"/>

		<!-- Theme selector -->
		<StackPanel Spacing="8">
			<TextBlock Text="Тема" FontSize="14" Opacity="0.6"/>
			<ComboBox ItemsSource="{Binding Themes}"
					  SelectedItem="{Binding SelectedTheme}"
					  HorizontalAlignment="Stretch"/>
		</StackPanel>

		<!-- RAWG API key -->
		<StackPanel Spacing="8">
			<TextBlock Text="RAWG API Key" FontSize="14" Opacity="0.6"/>
			<TextBlock Text="Отримати ключ: rawg.io/apidocs" FontSize="11" Opacity="0.4"/>
			<TextBox Text="{Binding RawgApiKey}"
					 PlaceholderText="Вставте API ключ або залиште порожнім..."/>
			<Button Content="Перевірити ключ"
					Command="{Binding ValidateRawgKeyCommand}"
					IsEnabled="{Binding !IsValidatingKey}"/>
			<TextBlock Text="{Binding RawgKeyStatusMessage}"
					   FontSize="12"
					   IsVisible="{Binding RawgKeyStatusMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
		</StackPanel>

		<!-- Connection status indicator -->
		<StackPanel Orientation="Horizontal" Spacing="6">
			<TextBlock Text="●" FontSize="10" VerticalAlignment="Center"
					   Foreground="#4caf50" IsVisible="{Binding IsOnline}"/>
			<TextBlock Text="●" FontSize="10" VerticalAlignment="Center"
					   Foreground="#888" IsVisible="{Binding !IsOnline}"/>
			<TextBlock Text="{Binding ConnectionStatus}"
					   FontSize="12" Opacity="0.6"
					   VerticalAlignment="Center"/>
		</StackPanel>

		<!-- Disk capacity -->
		<StackPanel Spacing="8">
			<TextBlock Text="Розмір диску (ГБ)"
					   FontSize="14" Opacity="0.6"/>
			<NumericUpDown Value="{Binding DiskCapacityGB, Converter={x:Static conv:DecimalToDoubleConverter.Instance}}"
						   Minimum="0" Maximum="100000" Increment="100" FormatString="0"/>
			<TextBlock Text="{Binding DiskOverflowError}"
					   Foreground="#F44336" FontSize="12"
					   IsVisible="{Binding HasDiskOverflowError}"/>
		</StackPanel>

	</StackPanel>
</UserControl>